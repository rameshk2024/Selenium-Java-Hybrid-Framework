<configration status="WARN">

	<Appenders>
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout
				pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n">

			</PatternLayout>
		</Console>
		<File name="File" filename="logs/test.log">
			<Filters>
				<!-- Exclude errors and fatals-->
				<thresholdfilter level="error" onMatch="DENY"
					onMisMatch="ACCEPT" />
			</Filters>
			<PatternLayout
				pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n">

			</PatternLayout>
		</File>
		<File name="ErrorFileLogger" filename="logs/error.log" append="true">
			<Filters>
				<!-- Include only errors and fatals-->
				<thresholdfilter level="error" onMatch="ACCEPT"
					onMisMatch="DENY" />
			</Filters>
			<PatternLayout
				pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n">

			</PatternLayout>
		</File>
	</Appenders>
	<Loggers>
		<Root level="info">
			<AppenderRef ref="Console" />
			<AppenderRef ref="File" />
			<AppenderRef ref="ErrorFileLogger" />

		</Root>
	</Loggers>

</configration>